<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Burpee Blaster | Mindful Fitness Gym | Chennai</title>
  <meta name="description" content="Chennai's mindful fitness studio offering guided training, group meditation, nutrition consultation, and exclusive badminton & pickleball memberships for individuals, couples and families." />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --blue: #7FB3D3;
      --blue-dark: #5a96bc;
      --blue-light: #d4eaf6;
      --orange: #E8521A;
      --orange-light: #f47342;
      --charcoal: #1A1A2E;
      --white: #ffffff;
      --off-white: #f9fbfd;
      --text-muted: #5a6a7a;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--charcoal);
      background: var(--white);
      overflow-x: hidden;
    }

    h1, h2, h3, h4 { font-family: 'Playfair Display', serif; }

    /* ── NAVBAR ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 5%; height: 72px;
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 24px rgba(127,179,211,0.15);
      transition: box-shadow 0.3s;
    }
    .logo {
      display: flex; align-items: center;
      text-decoration: none;
    }
    .logo img { height: 52px; width: auto; object-fit: contain; }

    .nav-links { display: flex; align-items: center; gap: 32px; list-style: none; }
    .nav-links a { text-decoration: none; color: var(--charcoal); font-size: 14px; font-weight: 500; letter-spacing: 0.3px; transition: color 0.2s; }
    .nav-links a:hover { color: var(--orange); }
    .nav-cta {
      background: var(--orange); color: var(--white) !important;
      padding: 10px 22px; border-radius: 50px;
      font-weight: 600 !important; transition: background 0.2s, transform 0.2s !important;
    }
    .nav-cta:hover { background: var(--orange-light) !important; transform: translateY(-1px); }

    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; border: none; background: none; padding: 4px; }
    .hamburger span { display: block; width: 24px; height: 2px; background: var(--charcoal); border-radius: 2px; transition: all 0.3s; }

    /* ── HERO ── */
    #hero {
      min-height: 100vh;
      background: linear-gradient(135deg, var(--blue) 0%, #5a9ec4 60%, #3a7fa8 100%);
      display: flex; align-items: center;
      padding: 120px 5% 80px;
      position: relative; overflow: hidden;
    }
    .hero-bg-circle {
      position: absolute; right: -8%; top: 50%; transform: translateY(-50%);
      width: min(680px, 90vw); aspect-ratio: 1;
      background: rgba(255,255,255,0.07);
      border-radius: 50% 50% 0 0;
      pointer-events: none;
    }
    .hero-bg-circle::before {
      content: '';
      position: absolute; inset: 10%;
      background: rgba(255,255,255,0.05);
      border-radius: 50% 50% 0 0;
    }
    .hero-orb {
      position: absolute; right: 18%; top: 42%;
      width: 90px; height: 90px;
      background: radial-gradient(circle at 35% 35%, #f5a623, var(--orange));
      border-radius: 50%;
      box-shadow: 0 8px 40px rgba(232,82,26,0.5);
      animation: float 4s ease-in-out infinite;
    }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-18px)} }

    .hero-content { max-width: 580px; position: relative; z-index: 2; animation: fadeUp 0.9s ease both; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.18); color: var(--white);
      padding: 6px 16px; border-radius: 50px; font-size: 12px;
      letter-spacing: 1.5px; text-transform: uppercase; font-weight: 600;
      margin-bottom: 28px; border: 1px solid rgba(255,255,255,0.3);
      animation: fadeUp 0.9s 0.1s ease both;
    }
    .hero-badge span { width: 6px; height: 6px; background: var(--orange); border-radius: 50%; display: inline-block; }

    #hero h1 {
      font-size: clamp(42px, 6vw, 72px);
      color: var(--white); line-height: 1.08;
      margin-bottom: 24px;
      animation: fadeUp 0.9s 0.2s ease both;
    }
    #hero h1 em { font-style: italic; color: rgba(255,255,255,0.75); }

    .hero-sub {
      font-size: 18px; color: rgba(255,255,255,0.88);
      line-height: 1.7; margin-bottom: 44px; font-weight: 300;
      animation: fadeUp 0.9s 0.3s ease both;
    }
    .hero-btns { display: flex; gap: 16px; flex-wrap: wrap; animation: fadeUp 0.9s 0.4s ease both; }
    .btn-primary {
      background: var(--orange); color: var(--white);
      padding: 16px 32px; border-radius: 50px; font-size: 15px;
      font-weight: 600; text-decoration: none; border: none; cursor: pointer;
      transition: all 0.25s; display: inline-flex; align-items: center; gap: 8px;
      font-family: 'DM Sans', sans-serif;
    }
    .btn-primary:hover { background: var(--orange-light); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(232,82,26,0.4); }
    .btn-outline {
      background: transparent; color: var(--white);
      padding: 16px 32px; border-radius: 50px; font-size: 15px;
      font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.6);
      transition: all 0.25s; display: inline-flex; align-items: center; gap: 8px;
      font-family: 'DM Sans', sans-serif; cursor: pointer;
    }
    .btn-outline:hover { background: rgba(255,255,255,0.15); border-color: white; }

    .hero-stats {
      display: flex; gap: 40px; margin-top: 60px; flex-wrap: wrap;
      animation: fadeUp 0.9s 0.5s ease both;
    }
    .stat { color: var(--white); }
    .stat-num { font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 900; line-height: 1; }
    .stat-label { font-size: 12px; opacity: 0.75; letter-spacing: 1px; text-transform: uppercase; margin-top: 4px; }

    /* ── SECTION COMMONS ── */
    section { padding: 100px 5%; }
    .section-label {
      font-size: 11px; letter-spacing: 2.5px; text-transform: uppercase;
      font-weight: 600; color: var(--orange); margin-bottom: 12px;
    }
    .section-heading {
      font-size: clamp(32px, 4vw, 52px); line-height: 1.15;
      margin-bottom: 16px;
    }
    .section-sub {
      font-size: 17px; color: var(--text-muted); line-height: 1.7;
      max-width: 560px; font-weight: 300;
    }
    .section-header { margin-bottom: 64px; }
    .text-center { text-align: center; }
    .text-center .section-sub { margin: 0 auto; }

    /* ── HOW IT WORKS ── */
    #how { background: var(--off-white); }
    .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
    .step-card {
      background: var(--white); border-radius: 24px;
      padding: 44px 36px; position: relative;
      border: 1px solid rgba(127,179,211,0.2);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .step-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(127,179,211,0.2); }
    .step-num {
      font-family: 'Playfair Display', serif;
      font-size: 72px; font-weight: 900;
      color: var(--orange); opacity: 0.12;
      position: absolute; top: 20px; right: 28px;
      line-height: 1;
    }
    .step-icon {
      width: 56px; height: 56px; border-radius: 16px;
      background: linear-gradient(135deg, var(--blue-light), var(--blue));
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; margin-bottom: 24px;
    }
    .step-card h3 { font-size: 22px; margin-bottom: 12px; }
    .step-card p { color: var(--text-muted); line-height: 1.7; font-size: 15px; }
    .steps-cta { text-align: center; margin-top: 56px; }
    .steps-cta small { display: block; margin-top: 12px; color: var(--text-muted); font-style: italic; font-size: 13px; }

    /* ── MEMBERSHIPS ── */
    #memberships { background: var(--blue); }
    #memberships .section-label { color: rgba(255,255,255,0.7); }
    #memberships .section-heading { color: var(--white); }
    #memberships .section-sub { color: rgba(255,255,255,0.75); }
    .membership-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .membership-card {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 28px; padding: 44px 36px;
      backdrop-filter: blur(8px);
      transition: all 0.3s; position: relative; overflow: hidden;
    }
    .membership-card.featured {
      background: var(--white);
      border-color: var(--white);
      transform: scale(1.04);
      box-shadow: 0 24px 80px rgba(0,0,0,0.2);
    }
    .membership-card:hover:not(.featured) { background: rgba(255,255,255,0.2); transform: translateY(-4px); }
    .tier-badge {
      display: inline-block; font-size: 11px; letter-spacing: 2px;
      text-transform: uppercase; font-weight: 700;
      padding: 5px 14px; border-radius: 50px; margin-bottom: 20px;
    }
    .silver .tier-badge { background: rgba(255,255,255,0.2); color: var(--white); }
    .gold .tier-badge { background: var(--orange); color: var(--white); }
    .platinum .tier-badge { background: var(--charcoal); color: var(--white); }
    .membership-card.featured .tier-badge { background: var(--blue); color: var(--white); }
    .membership-card h3 { font-size: 28px; margin-bottom: 6px; }
    .silver h3, .silver .tier-sub { color: var(--white); }
    .platinum h3, .platinum .tier-sub { color: var(--white); }
    .gold h3 { color: var(--charcoal); }
    .tier-sub { font-size: 13px; opacity: 0.7; margin-bottom: 28px; font-style: italic; }
    .gold .tier-sub { color: var(--text-muted); }
    .tier-divider { height: 1px; background: rgba(255,255,255,0.2); margin-bottom: 28px; }
    .gold .tier-divider { background: rgba(127,179,211,0.25); }
    .tier-benefits { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-bottom: 36px; }
    .tier-benefits li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; line-height: 1.5; }
    .silver .tier-benefits li, .platinum .tier-benefits li { color: rgba(255,255,255,0.9); }
    .gold .tier-benefits li { color: var(--text-muted); }
    .tier-benefits li::before { content: '✓'; color: var(--orange); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .gold .tier-benefits li::before { color: var(--blue-dark); }
    .btn-tier {
      display: block; text-align: center; padding: 14px;
      border-radius: 50px; font-weight: 600; font-size: 14px;
      text-decoration: none; transition: all 0.25s; cursor: pointer;
      font-family: 'DM Sans', sans-serif; border: none;
    }
    .silver .btn-tier, .platinum .btn-tier { background: rgba(255,255,255,0.2); color: var(--white); border: 1px solid rgba(255,255,255,0.4); }
    .silver .btn-tier:hover, .platinum .btn-tier:hover { background: rgba(255,255,255,0.35); }
    .gold .btn-tier { background: var(--orange); color: var(--white); }
    .gold .btn-tier:hover { background: var(--orange-light); }
    .membership-note {
      text-align: center; margin-top: 52px;
      color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.7;
    }

    /* ── SUCCESS STORIES ── */
    #stories { background: var(--off-white); }
    .stories-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; align-items: stretch; }
    .story-card {
      background: var(--white); border-radius: 24px; overflow: hidden;
      border: 1px solid rgba(127,179,211,0.15);
      transition: transform 0.3s, box-shadow 0.3s;
      display: flex; flex-direction: column;
    }
    .story-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(127,179,211,0.2); }
    .story-img {
      height: 280px; display: flex; align-items: center; justify-content: center;
      font-size: 64px; position: relative; overflow: hidden; flex-shrink: 0;
    }
    .story-img img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
    .story-img.blue { background: linear-gradient(135deg, var(--blue-light), var(--blue)); }
    .story-img.orange { background: linear-gradient(135deg, #fff3ee, #ffd9c8); }
    .story-img.teal { background: linear-gradient(135deg, #e8f7f4, #b2ddd6); }
    .story-img.warm { background: linear-gradient(135deg, #fef9e8, #fde68a); }
    .story-body { padding: 28px; display: flex; flex-direction: column; flex: 1; }
    .story-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .story-avatar {
      width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
      background: var(--blue); display: flex; align-items: center; justify-content: center;
      font-family: 'Playfair Display', serif; font-size: 18px; color: white; font-weight: 700;
    }
    .story-name { font-weight: 600; font-size: 15px; }
    .story-tier { font-size: 12px; color: var(--orange); font-weight: 600; letter-spacing: 0.5px; }
    .story-body p { color: var(--text-muted); font-size: 14px; line-height: 1.75; margin-bottom: 20px; flex: 1; }
    .story-quote {
      border-left: 3px solid var(--orange); padding-left: 16px;
      font-style: italic; color: var(--charcoal); font-size: 15px;
      line-height: 1.6; font-family: 'Playfair Display', serif;
      margin-top: auto;
    }
    .stories-cta { text-align: center; margin-top: 56px; }

    @media (max-width: 1024px) {
      .stories-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
    }

    /* ── TESTIMONIALS ── */
    #testimonials { background: var(--blue); }
    #testimonials .section-label { color: rgba(255,255,255,0.65); }
    #testimonials .section-heading { color: var(--white); }
    .testi-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; }
    .testi-card {
      background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
      border-radius: 24px; padding: 36px 32px;
      backdrop-filter: blur(6px); transition: all 0.3s;
    }
    .testi-card:hover { background: rgba(255,255,255,0.2); transform: translateY(-4px); }
    .stars { color: #fbbf24; font-size: 16px; margin-bottom: 16px; letter-spacing: 2px; }
    .testi-card blockquote {
      font-style: italic; color: rgba(255,255,255,0.9);
      font-size: 15px; line-height: 1.75; margin-bottom: 24px;
      font-family: 'Playfair Display', serif;
    }
    .testi-author { display: flex; align-items: center; gap: 12px; }
    .testi-avatar {
      width: 42px; height: 42px; border-radius: 50%;
      background: rgba(255,255,255,0.25);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Playfair Display', serif; font-size: 16px;
      color: white; font-weight: 700; flex-shrink: 0;
    }
    .testi-name { font-weight: 600; color: white; font-size: 14px; }
    .testi-tier { font-size: 12px; color: rgba(255,255,255,0.6); }
    .review-cta {
      text-align: center; margin-top: 56px;
      border-top: 1px solid rgba(255,255,255,0.15); padding-top: 48px;
    }
    .review-cta p { color: rgba(255,255,255,0.75); margin-bottom: 20px; font-size: 16px; }
    .btn-review {
      display: inline-flex; align-items: center; gap: 8px;
      border: 2px solid rgba(255,255,255,0.6); color: white;
      padding: 12px 28px; border-radius: 50px; font-weight: 600;
      text-decoration: none; transition: all 0.25s; font-size: 14px;
      font-family: 'DM Sans', sans-serif;
    }
    .btn-review:hover { background: rgba(255,255,255,0.15); border-color: white; }

    /* ── LEGACY BANNER ── */
    #legacy {
      background: var(--charcoal);
      padding: 80px 5%;
    }
    .legacy-inner {
      max-width: 760px; margin: 0 auto; text-align: center;
    }
    .legacy-emoji { font-size: 48px; margin-bottom: 20px; display: block; }
    #legacy h2 { color: var(--white); font-size: clamp(28px, 3.5vw, 44px); margin-bottom: 20px; }
    #legacy p { color: rgba(255,255,255,0.7); font-size: 17px; line-height: 1.8; margin-bottom: 36px; font-weight: 300; }

    /* ── ABOUT ── */
    #about { background: var(--white); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .about-img {
      border-radius: 28px; overflow: hidden; position: relative;
      background: linear-gradient(135deg, var(--blue-light) 0%, var(--blue) 100%);
      aspect-ratio: 4/5; display: flex; align-items: center; justify-content: center;
    }
    .about-img-inner { text-align: center; }
    .about-img-inner span { font-size: 80px; display: block; margin-bottom: 12px; }
    .about-img-inner p { color: rgba(255,255,255,0.8); font-size: 14px; letter-spacing: 1px; text-transform: uppercase; }
    .about-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 28px; }
    .badge {
      background: var(--blue-light); color: var(--blue-dark);
      padding: 6px 16px; border-radius: 50px; font-size: 13px; font-weight: 600;
    }
    #about p { color: var(--text-muted); line-height: 1.8; font-size: 16px; margin-bottom: 28px; font-weight: 300; }

    /* ── FAQ ── */
    #faq { background: var(--off-white); }
    .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .faq-item {
      background: var(--white); border-radius: 20px;
      padding: 32px 36px; border: 1px solid rgba(127,179,211,0.15);
      cursor: pointer; transition: box-shadow 0.3s;
    }
    .faq-item:hover { box-shadow: 0 8px 32px rgba(127,179,211,0.15); }
    .faq-q {
      font-weight: 600; font-size: 16px; color: var(--charcoal);
      display: flex; justify-content: space-between; align-items: center; gap: 16px;
    }
    .faq-q::after { content: '+'; color: var(--orange); font-size: 22px; font-weight: 300; flex-shrink: 0; transition: transform 0.3s; }
    .faq-item.open .faq-q::after { transform: rotate(45deg); }
    .faq-a { color: var(--text-muted); font-size: 14px; line-height: 1.75; margin-top: 16px; display: none; }
    .faq-item.open .faq-a { display: block; }

    /* ── LOCATION ── */
    #location { background: var(--blue); }
    #location .section-label { color: rgba(255,255,255,0.7); }
    #location .section-heading { color: var(--white); }
    .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
    .map-placeholder {
      background: rgba(255,255,255,0.15); border-radius: 24px;
      height: 340px; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 12px;
      border: 1px solid rgba(255,255,255,0.25);
      color: white; font-size: 48px;
      overflow: hidden;
    }
    .map-placeholder p { font-size: 14px; opacity: 0.75; letter-spacing: 0.5px; }
    .map-placeholder a { color: rgba(255,255,255,0.85); font-size: 13px; text-decoration: underline; }
    .location-details { display: flex; flex-direction: column; gap: 24px; }
    .loc-item { display: flex; gap: 16px; align-items: flex-start; }
    .loc-icon {
      width: 44px; height: 44px; border-radius: 12px;
      background: rgba(255,255,255,0.15); display: flex;
      align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;
    }
    .loc-label { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.6); margin-bottom: 4px; font-weight: 600; }
    .loc-value { color: white; font-size: 15px; line-height: 1.6; }

    /* ── FINAL CTA ── */
    #cta {
      background: linear-gradient(135deg, #5a9ec4, var(--blue));
      text-align: center; padding: 120px 5%;
    }
    #cta h2 { color: white; font-size: clamp(36px, 5vw, 64px); margin-bottom: 16px; }
    #cta p { color: rgba(255,255,255,0.8); font-size: 18px; margin-bottom: 44px; font-weight: 300; max-width: 500px; margin-left: auto; margin-right: auto; }

    /* ── FOOTER ── */
    footer {
      background: var(--charcoal);
      padding: 80px 5% 40px;
    }
    .footer-grid {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 60px; margin-bottom: 60px;
    }
    .footer-brand .logo-text strong { color: white; font-size: 18px; }
    .footer-brand .logo-text span { color: var(--blue); }
    .footer-tagline { color: rgba(255,255,255,0.5); font-size: 14px; line-height: 1.7; margin-top: 16px; }
    .footer-col h4 { color: white; font-family: 'DM Sans', sans-serif; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 700; margin-bottom: 20px; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col ul li a { color: rgba(255,255,255,0.55); text-decoration: none; font-size: 14px; transition: color 0.2s; }
    .footer-col ul li a:hover { color: var(--orange); }
    .contact-item { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 12px; }
    .contact-item span:first-child { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
    .contact-item a, .contact-item p { color: rgba(255,255,255,0.55); font-size: 14px; text-decoration: none; line-height: 1.5; transition: color 0.2s; }
    .contact-item a:hover { color: var(--orange); }
    .social-links { display: flex; gap: 12px; margin-top: 4px; }
    .social-link {
      width: 38px; height: 38px; border-radius: 10px;
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);
